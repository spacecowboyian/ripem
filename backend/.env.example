# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://api.ripem.app/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ripem

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ripem-media

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Apple OAuth
APPLE_APP_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Sentry
SENTRY_DSN=
